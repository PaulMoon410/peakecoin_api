{
  "name": "peake_ui",
  "description": "Lightweight UI toolkit for PeakeCoin website aesthetics and quick page setup.",
  "features": [
    "Scroll reveal animations",
    "Dark/light theme toggle",
    "Simple header/footer rendering",
    "Sparkle background effect"
  ],
  "usage": {
    "cdn_js": "https://cdn.jsdelivr.net/gh/PaulMoon410/peakecoin_api/peake_ui.js",
    "cdn_css": "https://cdn.jsdelivr.net/gh/PaulMoon410/peakecoin_api/peake_ui.css",
    "example": [
      "<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/gh/PaulMoon410/peakecoin_api/peake_ui.css\">",
      "<script src=\"https://cdn.jsdelivr.net/gh/PaulMoon410/peakecoin_api/peake_ui.js\"></script>",
      "<script>PeakeUI.init({ backgroundEffects: true });</script>"
    ]
  }
}
